# Environment variables for local development
# Do NOT commit a populated .env file — secrets must come from Key Vault via Managed Identity.

# Azure AI Foundry
FOUNDRY_PROJECT_ENDPOINT=https://<your-foundry-project>.api.azureml.ms
FOUNDRY_MODEL_DEPLOYMENT_NAME=gpt-4o

# Microsoft Fabric Data Agent
DATA_AGENT_URL=https://<your-workspace>.fabric.microsoft.com/dataagents/<agent-id>/openai
FABRIC_DATA_AGENT_SERVER_URL="https://api.fabric.microsoft.com/v1/mcp/workspaces/<your-workspace>/dataagents/<agent-id>/agent"
# Tool name registered in the Fabric Data Agent (shown in Fabric portal)
FABRIC_DATA_AGENT_TOOL_NAME="TruckAgent"
FABRIC_TOOL_MODE="fabric_data_agent" # Set to "azure_ai_foundry" to use Azure AI Foundry instead of Fabric Data Agent